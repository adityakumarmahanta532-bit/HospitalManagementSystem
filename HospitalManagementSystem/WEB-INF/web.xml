<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://java.sun.com/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee
          http://java.sun.com/xml/ns/javaee/web-app_3_0.xsd"
         version="3.0"
         metadata-complete="true">
    
    <display-name>Hospital Management System</display-name>

    <!-- Initializer -->
    <listener>
        <listener-class>com.hms.util.DataInitializer</listener-class>
    </listener>

    <!-- Filters -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.hms.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Servlets -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.hms.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DoctorLoginServlet</servlet-name>
        <servlet-class>com.hms.servlet.DoctorLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DoctorLoginServlet</servlet-name>
        <url-pattern>/doctor/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PatientLoginServlet</servlet-name>
        <servlet-class>com.hms.servlet.PatientLoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientLoginServlet</servlet-name>
        <url-pattern>/patient/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.hms.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.hms.servlet.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ReceptionistDashboardServlet</servlet-name>
        <servlet-class>com.hms.servlet.ReceptionistDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReceptionistDashboardServlet</servlet-name>
        <url-pattern>/receptionist/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DoctorDashboardServlet</servlet-name>
        <servlet-class>com.hms.servlet.DoctorDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DoctorDashboardServlet</servlet-name>
        <url-pattern>/doctor/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PatientDashboardServlet</servlet-name>
        <servlet-class>com.hms.servlet.PatientDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientDashboardServlet</servlet-name>
        <url-pattern>/patient/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AppointmentServlet</servlet-name>
        <servlet-class>com.hms.servlet.AppointmentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AppointmentServlet</servlet-name>
        <url-pattern>/appointment/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PatientServlet</servlet-name>
        <servlet-class>com.hms.servlet.PatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientServlet</servlet-name>
        <url-pattern>/admin/patient/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DoctorServlet</servlet-name>
        <servlet-class>com.hms.servlet.DoctorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DoctorServlet</servlet-name>
        <url-pattern>/admin/doctor/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>StaffServlet</servlet-name>
        <servlet-class>com.hms.servlet.StaffServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>StaffServlet</servlet-name>
        <url-pattern>/admin/staff/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PatientHistoryServlet</servlet-name>
        <servlet-class>com.hms.servlet.PatientHistoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientHistoryServlet</servlet-name>
        <url-pattern>/doctor/patient-history</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>BillingServlet</servlet-name>
        <servlet-class>com.hms.servlet.BillingServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BillingServlet</servlet-name>
        <url-pattern>/receptionist/billing</url-pattern>
    </servlet-mapping>

    <welcome-file-list>
        <welcome-file>login.jsp</welcome-file>
    </welcome-file-list>

</web-app>
